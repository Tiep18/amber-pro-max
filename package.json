{
  "name": "amigurumi-pattern-handmade-store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:security": "node --test tests/security/secret-boundary.test.mjs tests/security/catalog-boundaries.test.mjs tests/security/checkout-boundaries.test.mjs tests/security/payment-boundaries.test.mjs tests/security/fulfillment-boundaries.test.mjs tests/security/retention-boundaries.test.mjs tests/security/content-boundaries.test.mjs tests/security/operations-boundaries.test.mjs",
    "db:reset": "node scripts/reset-supabase.mjs",
    "db:lint": "supabase db lint --local --fail-on error",
    "db:test": "supabase test db",
    "db:types": "supabase gen types typescript --local > src/types/supabase.ts",
    "ci": "npm run lint && npm run typecheck && npm run test:unit && npm run db:reset && npm run db:lint && npm run db:test && npm run db:types && git diff --exit-code src/types/supabase.ts && npm run build && npm run test:security && npm run test:e2e"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-toggle": "^1.1.12",
    "@radix-ui/react-toggle-group": "^1.1.13",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.1",
    "@tailwindcss/postcss": "4.3.0",
    "date-fns": "4.4.0",
    "lucide-react": "1.17.0",
    "next": "16.2.9",
    "next-intl": "4.13.0",
    "postcss": "8.5.15",
    "radix-ui": "^1.6.0",
    "react": "19.2.7",
    "react-day-picker": "10.0.1",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.80.0",
    "resend": "6.14.0",
    "sonner": "^2.0.7",
    "tailwindcss": "4.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "22.18.4",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "10.4.1",
    "eslint-config-next": "16.2.9",
    "prettier": "3.8.4",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  }
}
