{
  "name": "amigurumi-pattern-handmade-store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:security": "node --test tests/security/*.test.mjs",
    "db:reset": "supabase db reset",
    "db:lint": "supabase db lint --local --fail-on error",
    "db:test": "supabase test db",
    "db:types": "supabase gen types typescript --local > src/types/supabase.ts",
    "ci": "npm run lint && npm run typecheck && npm run test:unit && npm run test:security && npm run build"
  },
  "dependencies": {
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.1",
    "@tailwindcss/postcss": "4.3.0",
    "lucide-react": "1.17.0",
    "next": "16.2.9",
    "next-intl": "4.13.0",
    "postcss": "8.5.15",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "22.18.4",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "10.4.1",
    "eslint-config-next": "16.2.9",
    "prettier": "3.8.4",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  }
}
